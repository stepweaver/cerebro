# Copy to credentials.env and fill in. credentials.env is gitignored.
# supabase secrets set --env-file credentials.env

SLACK_SIGNING_SECRET=replace_me
SLACK_CAPTURE_CHANNEL_ID=C01234567890
MCP_ACCESS_KEY=replace_with_long_random_string

# Optional (logs only)
# SLACK_CAPTURE_CHANNEL_NAME=

# Optional if not auto-injected
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
